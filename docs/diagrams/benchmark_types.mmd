        QA_D["CoQA · TriviaQA<br/>SQuAD-style QA"]
        GEN_D["WikiText · summarization<br/>open-ended generation"]
    end

    subgraph Metrics["Metrics"]
        MC_M["Accuracy<br/>(alternativa extraída)"]
        AR_M["Numeric match<br/>(resposta numérica)"]
        QA_M["Exact Match · F1<br/>(token overlap)"]
        GEN_M["BLEU · ROUGE<br/>(planned / stub)"]
    end

    MC --> MC_D --> MC_M
    AR --> AR_D --> AR_M
    QA --> QA_D --> QA_M
    GEN --> GEN_D --> GEN_M

    FACT["EvaluatorFactory.create()<br/>path + item heuristics"] --> MC & AR & QA & GEN

